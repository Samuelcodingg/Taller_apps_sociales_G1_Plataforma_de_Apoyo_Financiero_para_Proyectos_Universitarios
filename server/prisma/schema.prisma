// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
}

model Account {
  id               String            @id @default(uuid()) @map("id_account") @db.Char(36)
  email            String            @unique @db.VarChar(150)
  password         String            @db.VarChar(255)
  emailVerified    Boolean           @default(false) @map("email_verified")
  provider         String            @db.VarChar(50)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamp(0)
  lastLoginAt      DateTime?         @map("last_login_at") @db.Timestamp(0)
  isActive         Boolean           @default(true) @map("is_active")

  profile          Profile?
  createdCampaigns Campaign[]        @relation("CampaignCreator")
  campaignComments CommentCampaign[]
  donations        Donation[]        @relation("DonationDonor")
  accountRoles     AccountRole[]

  @@map("account")
}

model Role {
  id          String       @id @default(uuid()) @map("id_role") @db.Char(36)
  name        String       @unique @db.VarChar(50)
  description String?      @db.Text

  accountRoles AccountRole[]

  @@map("roles")
}

model AccountRole {
  accountId String   @map("id_account") @db.Char(36)
  roleId    String   @map("id_role") @db.Char(36)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(0)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([accountId, roleId])
  @@map("account_roles")
}

model Profile {
  id                 Int           @id @default(autoincrement()) @map("id_profile")
  accountId          String        @unique @map("id_account") @db.Char(36)
  names              String        @db.VarChar(150)
  surnames           String        @db.VarChar(150)
  birthDate          DateTime      @map("birth_date") @db.Date
  professionalCareer String?       @map("professional_career") @db.VarChar(150)
  photoUrl           String?       @map("photo_url") @db.Text
  biography          String?       @db.Text

  account     Account      @relation(fields: [accountId], references: [id])
  socialMedia SocialMedia[]

  @@map("profile")
}

model SocialMedia {
  id        Int     @id @default(autoincrement()) @map("id_social_media")
  profileId Int     @map("id_profile")
  link      String  @db.Text

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("social_media")
}

model Campaign {
  id            Int                @id @default(autoincrement()) @map("id_campaign")
  creatorId     String             @map("id_creator") @db.Char(36)
  title         String             @db.VarChar(200)
  description   String             @db.Text
  goalAmount    Decimal            @map("goal_amount") @db.Decimal(10, 2)
  currentAmount Decimal            @default(0) @map("current_amount") @db.Decimal(10, 2)
  status        String             @db.VarChar(50)
  endDate       DateTime           @map("end_date") @db.DateTime(0)
  createdAt     DateTime           @default(now()) @map("created_at") @db.DateTime(0)

  creator    Account            @relation("CampaignCreator", fields: [creatorId], references: [id])
  comments   CommentCampaign[]
  media      CampaignMedia[]
  updates    UpdateCampaign[]
  donations  Donation[]
  categories CampaignCategory[]

  @@map("campaign")
}

model Category {
  id   Int               @id @default(autoincrement()) @map("id_category")
  name String            @db.VarChar(100)

  campaigns CampaignCategory[]

  @@map("category")
}

model CampaignCategory {
  campaignId Int @map("id_campaign")
  categoryId Int @map("id_category")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([campaignId, categoryId])
  @@map("campaign_category")
}

model UpdateCampaign {
  id        Int      @id @default(autoincrement()) @map("id_update_campaign")
  campaignId Int     @map("id_campaign")
  title     String   @db.VarChar(150)
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(0)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("update_campaign")
}

model CampaignMedia {
  id        Int     @id @default(autoincrement()) @map("id_campaign_media")
  campaignId Int    @map("id_campaign")
  typeMedia String  @map("type_media") @db.VarChar(50)
  mediaUrl  String  @map("media_url") @db.Text

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_media")
}

model CommentCampaign {
  id        Int              @id @default(autoincrement()) @map("id_comment_campaign")
  campaignId Int             @map("id_campaign")
  accountId String           @map("id_account") @db.Char(36)
  content   String           @db.Text
  parentId  Int?             @map("parent_id")
  createdAt DateTime         @default(now()) @map("created_at") @db.DateTime(0)

  campaign Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  account  Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  parent   CommentCampaign?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  CommentCampaign[] @relation("CommentReplies")

  @@map("comment_campaign")
}

model Donation {
  id          Int      @id @default(autoincrement()) @map("id_donation")
  campaignId  Int      @map("id_campaign")
  donorId     String   @map("id_donor") @db.Char(36)
  amount      Decimal  @db.Decimal(10, 2)
  isAnonymous Boolean  @default(false) @map("is_anonymous")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donor    Account  @relation("DonationDonor", fields: [donorId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@map("donation")
}

model Payment {
  id            Int      @id @default(autoincrement()) @map("id_payment")
  donationId    Int      @map("id_donation")
  paymentMethod String   @map("payment_method") @db.VarChar(100)
  transactionId String   @map("transaction_id") @db.VarChar(150)
  status        String   @db.VarChar(50)
  createdAt     DateTime @default(now()) @map("created_at") @db.DateTime(0)

  donation Donation @relation(fields: [donationId], references: [id], onDelete: Cascade)

  @@map("payment")
}
